# === PulseTrader+ Backend Configuration ===

# --- LLM API Keys (Groq — free, fast, OpenAI-compatible) ---
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# --- LLM Failover Providers (optional — automatic fallback if Groq is rate-limited) ---
# Cerebras: https://cloud.cerebras.ai (free tier, OpenAI-compatible)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
# Google Gemini: https://aistudio.google.com/apikey (free, 15 RPM, no credit card)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Agentic Wallet ---
# This is the agent's onchain identity. Generate with:
#   node -e "const {generatePrivateKey}=require('viem/accounts');console.log(generatePrivateKey())"
AGENT_PRIVATE_KEY=

# --- X Layer Testnet ---
XLAYER_RPC_URL=https://testrpc.xlayer.tech/terigon
XLAYER_WSS_URL=wss://xlayertestws.okx.com
XLAYER_FLASHBLOCKS_RPC=https://testrpc.xlayer.tech/flashblocks
XLAYER_CHAIN_ID=1952

# --- Builder Code (16 characters) ---
# Register at: https://web3.okx.com/onchainos/dev-portal
# Or on testnet: call registerAuto on 0x33907e98d7392d95212b05ab03f091e02d7815bf
BUILDER_CODE=PULSETRDRV1XLYR0

# --- Deployed Contract Addresses (fill after running deploy script) ---
PUSDC_ADDRESS=
PWETH_ADDRESS=

# --- Server ---
PORT=3001
