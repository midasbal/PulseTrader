# === PulseTrader+ Backend Configuration ===
# Copy to backend/.env and fill in your values

# --- LLM API Keys (Groq — OpenAI compatible) ---
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE
LLM_MODEL=llama-3.3-70b-versatile

# --- Agentic Wallet (generate a throwaway key for testnet) ---
AGENT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# --- X Layer Testnet ---
XLAYER_RPC_URL=https://testrpc.xlayer.tech/terigon
XLAYER_WSS_URL=wss://xlayertestws.okx.com
XLAYER_FLASHBLOCKS_RPC=https://testrpc.xlayer.tech/flashblocks
XLAYER_CHAIN_ID=1952

# --- Builder Code (16 characters — ERC-8021) ---
BUILDER_CODE=PULSETRDRV1XLYR0

# --- Deployed Contract Addresses (deploy your own or use existing) ---
PUSDC_ADDRESS=0xYOUR_PUSDC_CONTRACT
PWETH_ADDRESS=0xYOUR_PWETH_CONTRACT

# --- Server ---
PORT=3001
